# Runtime
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_ORIGINS=http://localhost:5173,http://localhost:8080

# Demo workspace (fixed UUID used by the sample migration)
DEMO_TENANT_ID=11111111-1111-4111-8111-111111111111
DEMO_MODE=true
API_KEY=nexus-demo-key

# Infrastructure
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexusops
REDIS_URL=redis://localhost:6379

# Stripe test mode (optional; demo event generator works without these)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# HubSpot private app token (optional; actions are simulated when empty)
HUBSPOT_ACCESS_TOKEN=

# Slack incoming webhook URL (optional; actions are simulated when empty)
SLACK_WEBHOOK_URL=

# Frontend values read by Vite from this root .env
VITE_API_BASE_URL=http://localhost:4000
VITE_API_KEY=nexus-demo-key
VITE_TENANT_ID=11111111-1111-4111-8111-111111111111
